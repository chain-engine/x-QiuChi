# ============================================
# QiuChi 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ============================================

# ------------ MCP 服务器配置 ------------
# 服务器名称
MCP_SERVER_NAME=QiuChi

# 服务器版本
MCP_VERSION=1.0.0

# 传输层类型: stdio, sse, streamable-http
# - stdio: 用于 Claude Desktop 本地插件
# - sse: Server-Sent Events，用于 Web 应用
# - streamable-http: FastMCP 默认 HTTP 传输
MCP_TRANSPORT=streamable-http

# HTTP 监听地址
MCP_HOST=0.0.0.0

# HTTP 监听端口
MCP_PORT=8000

# ------------ 日志配置 ------------
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
MCP_LOG_LEVEL=INFO

# 日志输出目标: stderr, file, both
MCP_LOG_OUTPUT=stderr

# 启用日志文件输出 (设为任意值启用)
# MCP_LOG_FILE=1

# ------------ 外部 API 配置 ------------
# OpenWeatherMap API 密钥 (用于天气查询工具)
# 获取地址: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here

# ------------ 功能开关 ------------
# 注意: 功能开关目前通过 config.yaml 配置
# 如需通过环境变量控制，可自行扩展
